# Copy this file to .env.development.local (gitignored) and fill in your values.
# Vite will merge .env.development.local on top of .env.development at build time.

# --- Google OAuth Client ID ------------------------------------------------
# Leave empty to keep dev-bypass mode (auto-signs in as dev@localhost).
# To enable real Google Sign-In (supports both Schnucks org accounts and personal Gmail):
#   1. Open Google Cloud Console → APIs & Services → Credentials.
#   2. Create an "OAuth 2.0 Client ID" of type "Web application".
#   3. Under "Authorized JavaScript origins," add: http://localhost:3000
#   4. Copy the generated Client ID below.
# The same client ID must be set as GOOGLE_CLIENT_ID on the API server (see docker-compose.yml).
# See CLAUDE.md "Frontend — enabling real Google Sign-In" for the full walkthrough.
VITE_GOOGLE_CLIENT_ID=

# --- Chrome Extension ID ---------------------------------------------------
# To find your sideloaded extension ID:
#   1. Go to chrome://extensions
#   2. Enable Developer Mode
#   3. Find "Gem Factory Extractor" and copy the ID string
VITE_EXTENSION_ID=your-extension-id-here

# --- API base URL (optional) -----------------------------------------------
# Defaults to same-origin /api via the Vite dev proxy. Override if needed.
# VITE_API_BASE_URL=
